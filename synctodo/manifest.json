{
  "id": "synctodo",
  "name": "SyncTodo",
  "version": "1.0.0",
  "minNoctaliaVersion": "3.6.0",
  "author": "aeroboislayys",
  "license": "MIT",
  "repository": "https://github.com/aeroslayys/Noctalia-Aero-plugins",
  "directory": "synctodo",
  "description": "Displays your SyncTodo tasks as a desktop widget and bar indicator. Reads from the local JSON cache written by the SyncTodo TUI.",
  "tags": ["Desktop Widget", "Bar", "Productivity"],
  "entryPoints": {
    "barWidget": "BarWidget.qml",
    "desktopWidget": "DesktopWidget.qml",
    "desktopWidgetSettings": "DesktopWidgetSettings.qml"
  },
  "dependencies": {
    "plugins": []
  },
  "metadata": {
    "defaultSettings": {
      "maxItems": 5,
      "showDone": false,
      "cachePath": "~/.cache/synctodo/cache.json"
    }
  }
}